# ─────────────────────────────────────────────────────────────
#  ABC Safety Solutions — Production Environment
#  Copy this file to .env and fill in every CHANGE_THIS value.
#  NEVER commit the real .env to version control.
# ─────────────────────────────────────────────────────────────

# ---- MySQL -------------------------------------------------------
# Root password used by the mysql container
MYSQL_ROOT_PASSWORD=CHANGE_THIS_STRONG_ROOT_PASSWORD

# App database credentials (must match DB_* vars below)
DB_HOST=mysql
DB_PORT=3306
DB_USER=abc
DB_PASSWORD=CHANGE_THIS_STRONG_APP_PASSWORD
DB_NAME=abc_portal

# ---- Application -------------------------------------------------
NODE_ENV=production
PORT=3000

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_THIS_LONG_RANDOM_SECRET_AT_LEAST_48_CHARS
JWT_EXPIRES_IN=7d

# Directory inside the container where uploads are stored
UPLOAD_DIR=./uploads

# Public-facing base URL of this server (no trailing slash).
# Used to build /uploads/* URLs returned by the image upload endpoint.
# Example: http://165.22.100.50  or  https://training.yourcompany.com
PUBLIC_BASE_URL=http://2.24.110.154

# ---- CORS --------------------------------------------------------
# Comma-separated list of allowed frontend origins.
# If frontend and backend are on the same domain (served via nginx), use that domain.
FRONTEND_URL=http://2.24.110.154

# ---- Stripe (course purchases) ----------------------------------
# See docs/STRIPE_SETUP.md. Test keys from Stripe Dashboard → Developers → API keys.
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# Frontend build (Vite): set VITE_STRIPE_ENABLED=true when deploying paid checkout.
# Frontend: VITE_DEBUG_LOGS=true prints API errors to the browser console in production builds.

# ---- Admin user (used by npm run admin:create) -------------------
# ADMIN_EMAIL=admin@yourcompany.com
# ADMIN_NAME=Admin
# ADMIN_PASSWORD=ChangeThisStrongPassword123!
