PORT=3000
NODE_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=abc
DB_PASSWORD=abc_secret
DB_NAME=abc_portal

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=http://localhost:3000

